#include <iostream>
#include <string>
#include <vector>

using namespace std;

// --- Base Class ---
class Item {
protected:
    int id;
    string title;
    bool isIssued;

public:
    Item(int i, string t) : id(i), title(t), isIssued(false) {}

    // Virtual destructor is important for inheritance
    virtual ~Item() {}

    // Pure virtual function makes this an Abstract Class
    virtual void displayDetails() const {
        cout << "ID: " << id << " | Title: " << title 
             << " | Status: " << (isIssued ? "Checked Out" : "Available");
    }

    void issueItem() {
        if (!isIssued) {
            isIssued = true;
            cout << "\nItem '" << title << "' has been issued.";
        } else {
            cout << "\nItem already issued!";
        }
    }

    void returnItem(int daysLate) {
        isIssued = false;
        cout << "\nItem '" << title << "' returned.";
        if (daysLate > 0) {
            calculateFine(daysLate);
        }
    }

    // Simple fine calculation logic
    void calculateFine(int days) {
        double finePerDay = 2.0; 
        cout << " Fine incurred: $" << (days * finePerDay);
    }

    bool getStatus() const { return isIssued; }
};

// --- Derived Class: Book ---
class Book : public Item {
private:
    string author;

public:
    Book(int i, string t, string a) : Item(i, t), author(a) {}

    void displayDetails() const override {
        Item::displayDetails(); // Reuse base class logic
        cout << " | Author: " << author << " [Type: Book]" << endl;
    }
};

// --- Derived Class: Magazine ---
class Magazine : public Item {
private:
    int issueNumber;

public:
    Magazine(int i, string t, int n) : Item(i, t), issueNumber(n) {}

    void displayDetails() const override {
        Item::displayDetails(); // Reuse base class logic
        cout << " | Issue No: " << issueNumber << " [Type: Magazine]" << endl;
    }
};

// --- Main Program ---
int main() {
    // Vector of pointers to handle Polymorphism
    vector<Item*> library;

    library.push_back(new Book(101, "The Great Gatsby", "F. Scott Fitzgerald"));
    library.push_back(new Magazine(201, "National Geographic", 542));
    library.push_back(new Book(102, "1984", "George Orwell"));

    cout << "--- Library Inventory ---\n";
    int availableCount = 0;
    for (const auto& item : library) {
        item->displayDetails();
        if (!item->getStatus()) availableCount++;
    }
    cout << "\nTotal Items Available: " << availableCount << endl;

    // Simulate interactions
    library[0]->issueItem();
    library[0]->returnItem(3); // 3 days late

    // Cleanup memory
    for (auto item : library) delete item;

    return 0;
}